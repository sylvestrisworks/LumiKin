# PostgreSQL (Neon)
# Local dev: use the direct connection string from Neon dashboard
# Vercel: use the POOLED connection string (hostname ends in -pooler.*)
#   e.g. postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/playsmart

# Anthropic — auto-review script (--provider anthropic) AND content/UI translation
# (scripts/drain-translations.ts, scripts/translate-messages.ts). sv → Sonnet 4.6,
# de/fr/es → Haiku 4.5. See src/lib/anthropic.ts.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Vertex AI — for auto-review script (--provider google, default)
# Project ID from Google Cloud Console (not the project name, the ID)
GOOGLE_PROJECT_ID=your-gcloud-project-id
# Region — us-central1 has the best model availability
GOOGLE_LOCATION=us-central1

# RAWG — https://rawg.io/apidocs
RAWG_API_KEY=your_rawg_key_here

# IGDB via Twitch OAuth — https://dev.twitch.tv/console
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret

# NextAuth
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# Public site URL — used for sitemap, robots.txt, and canonical tags
# Set to your production domain in Vercel env vars
NEXT_PUBLIC_SITE_URL=https://lumikin.org

# Sanity CMS — create a project at sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# Sentry — error monitoring (DSN is public, safe to commit)
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz

# Azure OpenAI — debate-games cron (gpt-4o via Azure AI Foundry)
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://lumikin-openai.openai.azure.com

# Resend — transactional email for partner inquiries
# Create a free account at resend.com, verify the lumikin.org domain, and generate an API key.
# The "from" address used is partners@lumikin.org — add that as a sender in Resend.
# If unset, email is skipped but inquiries are still saved to the database.
RESEND_API_KEY=re_your_key_here

# ── Library import integrations ──────────────────────────────────────────────
# Steam Web API key — https://steamcommunity.com/dev/apikey (public GetOwnedGames)
STEAM_API_KEY=your_steam_web_api_key

# Epic Games — approved Epic dev app (OAuth + entitlements scope)
# https://dev.epicgames.com — set the redirect URI to <APP_URL>/api/epic/connect/callback
EPIC_CLIENT_ID=your_epic_client_id
EPIC_CLIENT_SECRET=your_epic_client_secret

# GOG — optional. Defaults to the public GOG Galaxy client credentials; only set
# these if GOG issues you a dedicated app. Uses the paste-the-redirect-URL flow.
GOG_CLIENT_ID=
GOG_CLIENT_SECRET=

# Token encryption at rest — 32 bytes, hex (64 chars) or base64 (44 chars).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Required to store Epic/GOG/Nintendo OAuth tokens (see src/lib/token-crypto.ts).
TOKEN_ENCRYPTION_KEY=generate_32_byte_base64_key

# Cron auth — Bearer secret the GitHub Actions sync workflows send.
CRON_SECRET=generate_a_long_random_string
# Base URL the sync workflows hit (also used for OAuth redirect URIs).
APP_URL=http://localhost:3000
